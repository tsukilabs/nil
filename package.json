{
  "name": "nil",
  "version": "0.5.0",
  "type": "module",
  "packageManager": "pnpm@11.0.6",
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "build": "cargo +nightly -Zscript scripts/build-client.rs",
    "bump": "cargo +nightly -Zscript scripts/bump.rs",
    "clean": "cargo +nightly -Zscript scripts/clean.rs",
    "clippy": "cargo +nightly -Zscript scripts/run-clippy.rs",
    "dev": "cargo +nightly -Zscript scripts/start-dev.rs",
    "docs": "cargo +nightly doc -p nil-* --open --no-deps --lib --document-private-items",
    "example": "cargo +nightly -Zscript scripts/run-example.rs",
    "format": "dprint fmt && cargo fmt --all",
    "generate-bindings": "cargo test export_bindings",
    "lint": "eslint . --config eslint.config.ts",
    "miri": "cargo +nightly -Zscript scripts/test.rs --miri",
    "preview": "cargo +nightly -Zscript scripts/build-client.rs --preview",
    "server": "cargo +nightly -Zscript scripts/start-server.rs",
    "test": "cargo +nightly -Zscript scripts/test.rs",
    "type-check": "pnpm run -r --bail type-check",
    "udeps": "cargo +nightly udeps"
  },
  "dependencies": {
    "@lucide/vue": "=1.14.0",
    "@tanstack/vue-table": "=8.21.3",
    "@tauri-apps/api": "=2.11.0",
    "@tauri-apps/plugin-clipboard-manager": "=2.3.2",
    "@tauri-apps/plugin-dialog": "=2.7.1",
    "@tauri-apps/plugin-fs": "=2.5.1",
    "@tauri-apps/plugin-opener": "=2.5.4",
    "@tauri-apps/plugin-os": "=2.3.2",
    "@tauri-apps/plugin-process": "=2.3.1",
    "@tauri-apps/plugin-updater": "=2.10.1",
    "@tauri-store/pinia": "=4.2.0",
    "@tb-dev/prototype-dom": "=7.0.44",
    "@tb-dev/utils": "=7.3.20",
    "@tb-dev/vue": "=4.0.22",
    "@tb-dev/vue-sonner": "=1.0.2",
    "@vueuse/components": "=14.3.0",
    "@vueuse/core": "=14.3.0",
    "@vueuse/math": "=14.3.0",
    "@vueuse/router": "=14.3.0",
    "class-variance-authority": "=0.7.1",
    "clsx": "=2.1.1",
    "date-fns": "=4.1.0",
    "es-toolkit": "=1.46.1",
    "pinia": "=3.0.4",
    "reka-ui": "=2.9.7",
    "tailwind-merge": "=3.5.0",
    "tw-animate-css": "=1.4.0",
    "vue": "=3.5.33",
    "vue-i18n": "=11.4.0",
    "vue-router": "=5.0.6",
    "zod": "=4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "=4.2.4",
    "@tauri-apps/cli": "=2.11.0",
    "@tb-dev/eslint-config": "=10.0.9",
    "@types/node": "=25.6.0",
    "@vitejs/plugin-vue": "=6.0.6",
    "eslint": "=10.3.0",
    "oxc-minify": "=0.129.0",
    "tailwindcss": "=4.2.4",
    "tslib": "=2.8.1",
    "typescript": "=6.0.3",
    "vite": "=8.0.10",
    "vitepress": "=2.0.0-alpha.17",
    "vue-tsc": "=3.2.8"
  }
}
